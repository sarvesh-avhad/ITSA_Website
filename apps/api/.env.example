# ===========================================
# ITSA Platform — Backend Environment Variables
# ===========================================

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1
CORS_ORIGIN=http://localhost:5173

# Database (use Docker Compose URL for local dev)
DATABASE_URL=postgresql://itsa:itsa_pass@localhost:5432/itsa_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=dev_access_secret_change_in_production_minimum_32_characters_long
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_minimum_32_characters_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=itsa-media
AWS_CLOUDFRONT_URL=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@itsa.example.com

# Sentry
SENTRY_DSN=

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=itsa-api
